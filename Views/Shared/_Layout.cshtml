@using System.Globalization
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<CoffeeHouse.SharedResource> SharedLocalizer

@{
    var isRtl = CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    var htmlDirection = isRtl ? "rtl" : "ltr";
    var htmlLanguage = CultureInfo.CurrentCulture.Name;
}

<!DOCTYPE html>

<html lang="@htmlLanguage" dir="@htmlDirection">

<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - @SharedLocalizer["CoffeeHouse"]
    </title>

    <script type="importmap"></script>

    @if (isRtl)
    {
        <link rel="stylesheet"
              href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    }
    else
    {
        <link rel="stylesheet"
              href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    }

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/CoffeeHouse.styles.css"
          asp-append-version="true" />
</head>

<body>

    <header>

        <nav class="navbar navbar-expand-lg coffee-navbar sticky-top">

            <div class="container">

                <a class="navbar-brand coffee-brand"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">

                    <i class="bi bi-cup-hot-fill me-2"></i>

                    @SharedLocalizer["CoffeeHouse"]

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#coffeeNavbar"
                        aria-controls="coffeeNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="coffeeNavbar">

                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Index">

                                @SharedLocalizer["Home"]

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-area=""
                               asp-controller="Products"
                               asp-action="Index">

                                @SharedLocalizer["Products"]

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-area=""
                               asp-controller="Categories"
                               asp-action="Index">

                                @SharedLocalizer["Categories"]

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Privacy">

                                @SharedLocalizer["Privacy"]

                            </a>

                        </li>

                        <li class="nav-item ms-lg-2">

                            <a class="btn coffee-nav-button"
                               asp-area=""
                               asp-controller="Products"
                               asp-action="Create">

                                <i class="bi bi-plus-circle me-1"></i>

                                @SharedLocalizer["AddProduct"]

                            </a>

                        </li>

                        <li class="nav-item dropdown ms-lg-2">

                            <button class="btn btn-outline-light dropdown-toggle"
                                    type="button"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">

                                <i class="bi bi-globe2 me-1"></i>

                                @(isRtl ? "العربية" : "English")

                            </button>

                            <ul class="dropdown-menu">

                                <li>

                                    <a class="dropdown-item"
                                       href="?culture=ar&ui-culture=ar">

                                        العربية

                                    </a>

                                </li>

                                <li>

                                    <a class="dropdown-item"
                                       href="?culture=en-US&ui-culture=en-US">

                                        English

                                    </a>

                                </li>

                            </ul>

                        </li>

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <main role="main">

        @RenderBody()

    </main>

    <footer class="coffee-footer">

        <div class="container">

            <div class="row align-items-center gy-3">

                <div class="col-md-6 text-center text-md-start">

                    <h5 class="mb-1">

                        <i class="bi bi-cup-hot-fill me-2"></i>

                        @SharedLocalizer["CoffeeHouse"]

                    </h5>

                    <p class="mb-0">
                        Fresh coffee, warm moments, and better days.
                    </p>

                </div>

                <div class="col-md-6 text-center text-md-end">

                    <a asp-area=""
                       asp-controller="Products"
                       asp-action="Index">

                        @SharedLocalizer["Products"]

                    </a>

                    <a asp-area=""
                       asp-controller="Categories"
                       asp-action="Index">

                        @SharedLocalizer["Categories"]

                    </a>

                    <a asp-area=""
                       asp-controller="Home"
                       asp-action="Privacy">

                        @SharedLocalizer["Privacy"]

                    </a>

                </div>

            </div>

            <hr />

            <p class="text-center mb-0">

                &copy; @DateTime.Now.Year
                @SharedLocalizer["CoffeeHouse"].
                All rights reserved.

            </p>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>