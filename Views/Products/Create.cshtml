@model CoffeeHouse.Models.Product

@{
    ViewData["Title"] = "Add Product";
}

<div class="container page-container">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="content-card">

                <div class="mb-4">
                    <h1 class="page-title mb-1">Add New Product</h1>

                    <p class="text-muted mb-0">
                        Add a new item to the CoffeeHouse menu.
                    </p>
                </div>

                <form asp-action="Create"
                      method="post"
                      enctype="multipart/form-data">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3"></div>

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label asp-for="Name"
                                   class="form-label"></label>

                            <input asp-for="Name"
                                   class="form-control"
                                   placeholder="Example: Spanish Latte" />

                            <span asp-validation-for="Name"
                                  class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Price"
                                   class="form-label"></label>

                            <div class="input-group">
                                <input asp-for="Price"
                                       class="form-control"
                                       placeholder="0.00" />

                                <span class="input-group-text">
                                    SAR
                                </span>
                            </div>

                            <span asp-validation-for="Price"
                                  class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CategoryId"
                                   class="form-label"></label>

                            <select asp-for="CategoryId"
                                    class="form-select"
                                    asp-items="ViewBag.CategoryId">
                                <option value="">
                                    Choose Category
                                </option>
                            </select>

                            <span asp-validation-for="CategoryId"
                                  class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ImageFile"
                                   class="form-label"></label>

                            <input asp-for="ImageFile"
                                   type="file"
                                   class="form-control"
                                   accept=".jpg,.jpeg,.png,.webp" />

                            <span asp-validation-for="ImageFile"
                                  class="text-danger"></span>

                            <small class="text-muted">
                                Choose an image from your device.
                            </small>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description"
                                   class="form-label"></label>

                            <textarea asp-for="Description"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Write a short product description..."></textarea>

                            <span asp-validation-for="Description"
                                  class="text-danger"></span>
                        </div>

                    </div>

                    <div class="d-flex gap-2 mt-4">

                        <button type="submit"
                                class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>
                            Save Product
                        </button>

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>
                            Back to Menu
                        </a>

                    </div>

                </form>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}