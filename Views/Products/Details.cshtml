@model CoffeeHouse.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="container page-container">

    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="content-card">

                <div class="row g-4 align-items-center">

                    <div class="col-md-6">
                        <img src="~/images/products/@Model.ImageUrl"
                             alt="@Model.Name"
                             class="img-fluid w-100 product-details-image"
                             onerror="this.src='/images/products/default.jpg';" />
                    </div>

                    <div class="col-md-6">

                        <span class="badge rounded-pill product-category mb-3">
                            @(Model.Category?.Name ?? "No Category")
                        </span>

                        <h1 class="page-title mb-3">
                            @Model.Name
                        </h1>

                        <p class="text-muted fs-5 mb-4">
                            @(string.IsNullOrWhiteSpace(Model.Description)
                                ? "No description available."
                                : Model.Description)
                        </p>

                        <div class="product-details-price mb-4">
                            @Model.Price.ToString("0.00") SAR
                        </div>

                        <div class="d-flex gap-2 flex-wrap">

                            <a asp-action="Edit"
                               asp-route-id="@Model.Id"
                               class="btn btn-primary">
                                <i class="bi bi-pencil-square me-1"></i>
                                Edit
                            </a>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>
                                Back to Menu
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@Model.Id"
                               class="btn btn-outline-danger">
                                <i class="bi bi-trash me-1"></i>
                                Delete
                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>
    </div>

</div>