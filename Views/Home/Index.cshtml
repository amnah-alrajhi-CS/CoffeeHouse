@model IEnumerable<CoffeeHouse.Models.Product>

@{
    ViewData["Title"] = "Coffee House";
}

<div class="container page-container">

    <div class="content-card text-center mb-5">
        <h1 class="display-3 fw-bold mb-3">
            Coffee House
        </h1>

        <p class="lead mb-4">
            Welcome to our coffee shop.
            Enjoy fresh coffee made with passion every day.
        </p>

        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Products"
               asp-action="Index"
               class="btn btn-primary btn-lg">
                View Menu
            </a>

            <a asp-controller="Categories"
               asp-action="Index"
               class="btn btn-outline-primary btn-lg">
                Categories
            </a>
        </div>
    </div>

    <div class="row g-4 mb-5">

        <div class="col-sm-6 col-lg-3">
            <div class="dashboard-card">
                <i class="bi bi-box-seam dashboard-icon"></i>
                <h2>@ViewBag.TotalProducts</h2>
                <p>Total Products</p>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3">
            <div class="dashboard-card">
                <i class="bi bi-grid dashboard-icon"></i>
                <h2>@ViewBag.TotalCategories</h2>
                <p>Categories</p>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3">
            <div class="dashboard-card">
                <i class="bi bi-cup-hot dashboard-icon"></i>
                <h2>@ViewBag.DrinksCount</h2>
                <p>Drinks</p>
            </div>
        </div>

        <div class="col-sm-6 col-lg-3">
            <div class="dashboard-card">
                <i class="bi bi-cake2 dashboard-icon"></i>
                <h2>@ViewBag.DessertsCount</h2>
                <p>Desserts</p>
            </div>
        </div>

    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title mb-1">Featured Products</h2>
            <p class="text-muted mb-0">
                Discover the latest items added to our menu.
            </p>
        </div>

        <a asp-controller="Products"
           asp-action="Index"
           class="btn btn-outline-primary">
            View All
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="content-card text-center">
            <h4>No products available</h4>
            <p class="text-muted mb-3">
                Add products to display them here.
            </p>

            <a asp-controller="Products"
               asp-action="Create"
               class="btn btn-primary">
                Add Product
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in Model)
            {
                <div class="col-md-4">
                    <div class="card product-card h-100 border-0 shadow-sm">

                        <img src="~/images/products/@product.ImageUrl"
                             class="card-img-top product-image"
                             alt="@product.Name"
                             onerror="this.src='/images/products/default.jpg';" />

                        <div class="card-body d-flex flex-column">

                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h4 class="card-title mb-0">
                                    @product.Name
                                </h4>

                                <span class="badge rounded-pill product-category">
                                    @(product.Category?.Name ?? "No Category")
                                </span>
                            </div>

                            <p class="text-muted flex-grow-1">
                                @(string.IsNullOrWhiteSpace(product.Description)
                                    ? "No description available."
                                    : product.Description)
                            </p>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="product-price">
                                    @product.Price.ToString("0.00") SAR
                                </span>

                                <a asp-controller="Products"
                                   asp-action="Details"
                                   asp-route-id="@product.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    Details
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>